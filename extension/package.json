{
  "name": "auto-ozon",
  "displayName": "auto-ozon v0.1.0",
  "version": "0.1.0",
  "description": "auto-ozon — Ozon/WB/1688/PDD 浏览器数据采集插件",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:chrome": "wxt build -b chrome",
    "typecheck": "wxt prepare && vue-tsc --noEmit",
    "prepare": "wxt prepare",
    "zip": "wxt zip && node -e \"const fs=require('node:fs');const p=require('./package.json');const from='.output/'+p.name+'-'+p.version+'-chrome.zip';const to='.output/'+p.name+'-v'+p.version+'-chrome.zip';if(fs.existsSync(from))fs.renameSync(from,to)\"",
    "zip:chrome": "npm run zip"
  },
  "dependencies": {
    "naive-ui": "^2.42.0",
    "vue": "^3.5.16"
  },
  "devDependencies": {
    "@wxt-dev/module-vue": "^1.0.2",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10",
    "wxt": "^0.20.27"
  }
}
